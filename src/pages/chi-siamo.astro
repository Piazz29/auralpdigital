---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import LiquidEther from "../components/reactbits/LiquidEther.jsx";
import BlurText from "../components/reactbits/BlurText.jsx";
import HangBadge from "../components/HangBadge.astro";
import FlowCardSwap from "../components/reactbits/FlowCardSwap.jsx";
import "../styles/global.css";

// IL DUO — ritratti e bio estese. `photo` è il path della foto reale in
// /public/about/ (finché è vuoto, la card mostra la cover brandizzata con
// l'iniziale, come sulla home).
const people = [
  {
    initial: "J",
    name: "Julian",
    nameEm: "",
    role: "Co-founder — Strategia & Sviluppo",
    grad: "grad-2",
    photo: "", // TODO: /about/julian.jpg
    bio: "Strategia, codice e sistemi. Julian progetta l'architettura di ogni progetto — dal posizionamento al deploy — e costruisce siti e gestionali con uno stack moderno e un workflow potenziato dall'AI. Se una cosa si può misurare, lui la misura.",
    focus: ["Strategia digitale", "Sviluppo web", "SEO + GEO", "AI & automazioni"],
  },
  {
    initial: "A",
    name: "Alice",
    nameEm: "",
    role: "Co-founder — Design & Contenuti",
    grad: "grad-4",
    photo: "", // TODO: /about/alice.jpg
    bio: "Design, contenuti e direzione visiva. Alice dà forma all'identità dei brand: interfacce pulite, fotografia curata e contenuti che parlano alle persone giuste con il tono giusto. Se un dettaglio stona, lei lo vede.",
    focus: ["Art direction", "UI & visual design", "Contenuti & social", "Fotografia"],
  },
];

// IL PERCORSO — tappe della storia. Ogni step porta un micro-SVG geometrico
// (linee bianche su badge scuro) animato in loop CSS, inerente al suo tema.
// `art` è la chiave che seleziona l'SVG; il lato (sx/dx) lo decide l'indice.
const steps = [
  {
    art: "uni",
    year: "Le basi",
    kicker: "La formazione",
    title: "Università.",
    text: "Il metodo nasce qui: analisi, ricerca e pensiero critico. Il percorso universitario ci ha dato il rigore che oggi applichiamo a ogni progetto — e non abbiamo mai smesso di studiare.",
  },
  {
    art: "spark",
    year: "La scintilla",
    kicker: "I primi progetti",
    title: "La prima riga di codice.",
    text: "I primi siti per attività locali dell'Alto Adige. È lì che capiamo una cosa semplice: ai professionisti non serve una vetrina, serve un sistema che porti clienti.",
  },
  {
    art: "studio",
    year: "Oggi",
    kicker: "Lo studio",
    title: "AuralpDigital.",
    text: "Uno studio digitale indipendente: strategia, design e tecnologia sotto lo stesso tetto, un workflow AI-augmented e un unico standard — fatto bene o rifatto.",
  },
  {
    art: "next",
    year: "Domani",
    kicker: "La direzione",
    title: "Sempre un passo avanti.",
    text: "Ogni nuova ondata tecnologica viene studiata, testata e — solo se funziona — portata nei progetti dei nostri clienti. Prima degli altri, mai a scapito della qualità.",
  },
];

// Icone-firma per gli step del percorso: SVG line-art (viewBox 64) coerenti
// col tema di ogni tappa, animati in loop via CSS (classi .ap-ico-*) dentro un
// badge grande con anello a gradiente rotante. Resi con set:html (statici e
// fidati). Reduced-motion congela i loop (vedi global.css).
const journeyArt: Record<string, string> = {
  // Università — tocco accademico con nappa che oscilla.
  uni: `<svg viewBox="0 0 64 64" fill="none" aria-hidden="true" class="ap-ico ap-ico--uni">
    <path class="ap-ico-line ap-ico-mortar" d="M6 25 L32 14 L58 25 L32 36 Z" stroke="currentColor" stroke-width="2.4" stroke-linejoin="round"/>
    <path class="ap-ico-line" d="M17 29.5 V41 C17 45.4 24 48.5 32 48.5 C40 48.5 47 45.4 47 41 V29.5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
    <g class="ap-ico-tassel">
      <line x1="58" y1="25" x2="58" y2="37" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
      <circle cx="58" cy="40" r="2.8" fill="currentColor"/>
    </g>
  </svg>`,
  // Prima riga di codice — finestra con tag e cursore che lampeggia + scintilla.
  spark: `<svg viewBox="0 0 64 64" fill="none" aria-hidden="true" class="ap-ico ap-ico--spark">
    <rect x="9" y="14" width="46" height="36" rx="5" stroke="currentColor" stroke-width="2.4"/>
    <line x1="9" y1="25" x2="55" y2="25" stroke="currentColor" stroke-width="2.4"/>
    <circle cx="15.5" cy="19.5" r="1.6" fill="currentColor"/>
    <circle cx="21.5" cy="19.5" r="1.6" fill="currentColor"/>
    <path class="ap-ico-line ap-ico-bk ap-ico-bk-l" d="M28 32 L22 38 L28 44" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
    <path class="ap-ico-line ap-ico-bk ap-ico-bk-r" d="M40 32 L46 38 L40 44" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
    <line class="ap-ico-caret" x1="33.5" y1="31" x2="31" y2="45" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
    <path class="ap-ico-sparkle" d="M50 8 L51.4 12 L55.4 13.4 L51.4 14.8 L50 18.8 L48.6 14.8 L44.6 13.4 L48.6 12 Z" fill="currentColor"/>
  </svg>`,
  // Studio — strati sotto lo stesso tetto (strategia · design · tecnologia).
  studio: `<svg viewBox="0 0 64 64" fill="none" aria-hidden="true" class="ap-ico ap-ico--studio">
    <path class="ap-ico-line ap-ico-layer ap-ico-layer-1" d="M32 11 L54 23 L32 35 L10 23 Z" stroke="currentColor" stroke-width="2.4" stroke-linejoin="round"/>
    <path class="ap-ico-line ap-ico-layer ap-ico-layer-2" d="M10 31 L32 43 L54 31" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
    <path class="ap-ico-line ap-ico-layer ap-ico-layer-3" d="M10 39 L32 51 L54 39" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  // Domani — freccia in avanti con satellite in orbita: sempre un passo avanti.
  next: `<svg viewBox="0 0 64 64" fill="none" aria-hidden="true" class="ap-ico ap-ico--next">
    <circle class="ap-ico-orbit-track" cx="32" cy="32" r="22" stroke="currentColor" stroke-width="1.4" stroke-dasharray="3 6" opacity="0.5"/>
    <path class="ap-ico-arrow" d="M20 44 L42 22 M30 21 L43 21 L43 34" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/>
    <g class="ap-ico-orbit"><circle cx="32" cy="10" r="2.8" fill="currentColor"/></g>
  </svg>`,
};

// COME LAVORIAMO — quattro fasi del metodo, ridisegnate come bento dark
// immersivo. Ogni card racconta anche dove l'AI entra nel processo.
const workflow = [
  {
    n: "01",
    title: "Ascolto",
    titleEm: "e analisi.",
    text: "Prima di disegnare qualsiasi cosa, capiamo il tuo mercato: chi cerca, cosa cerca, chi sono i concorrenti. L'AI accelera la ricerca e l'analisi dei dati — le conclusioni le tiriamo noi, insieme a te.",
    tag: "Ricerca",
  },
  {
    n: "02",
    title: "Design",
    titleEm: "con intenzione.",
    text: "Ogni scelta visiva ha uno scopo: guidare il visitatore verso un'azione. Con gli strumenti generativi esploriamo più direzioni in meno tempo, poi rifiniamo a mano quella giusta.",
    tag: "Art direction",
  },
  {
    n: "03",
    title: "Sviluppo",
    titleEm: "senza compromessi.",
    text: "Codice moderno, veloce, accessibile. L'AI scrive con noi e rivede ogni riga — ma niente va online senza essere passato sotto occhi umani, su dispositivi reali.",
    tag: "Build",
  },
  {
    n: "04",
    title: "Crescita",
    titleEm: "misurabile.",
    text: "Il lancio è l'inizio, non la fine: dati, test e ottimizzazioni continue. Ogni mese sai cosa è cambiato, perché, e cosa porta clienti.",
    tag: "Ottimizzazione",
  },
];
---

<BaseLayout
  title="Chi siamo — AuralpDigital"
  description="Le persone dietro AuralpDigital: un team indipendente in Alto Adige con formazione universitaria, strumenti di nuova generazione e un workflow potenziato dall'AI."
>
  <Navbar />

  <main class="aboutpage">
    <!-- HERO — aurora di palette, gerarchia centrata e arieggiata: badge,
         titolo dalla maschera, sottotitolo, riga di contesto. -->
    <section class="ap-hero">
      <div class="ap-hero-aurora" aria-hidden="true"></div>
      <!-- Sfondo fluido animato (LiquidEther) — reagisce al cursore e, in
           assenza di interazione, si muove da solo. Resta dietro al testo. -->
      <div class="ap-hero-fluid" aria-hidden="true">
        <LiquidEther
          client:load
          colors={["#f0f2f9", "#061657", "#3b5bdb"]}
          mouseForce={24}
          cursorSize={90}
          isViscous={false}
          resolution={0.5}
          autoDemo={true}
          autoSpeed={0.3}
          autoIntensity={2.2}
          takeoverDuration={0.25}
          autoResumeDelay={3000}
          autoRampDuration={0.6}
        />
      </div>

      <div class="ap-hero-inner">
        <span class="hero-badge ap-hero-badge" style="opacity: 0;">
          Chi siamo
        </span>

        <h1 class="ap-hero-title font-display" style="opacity: 0;">
          Le persone dietro <em>i pixel.</em>
        </h1>

        <p class="ap-hero-sub" style="opacity: 0;">
          Uno studio indipendente di due persone, dall'Alto Adige.
          Niente intermediari: chi ti risponde è chi progetta e costruisce.
        </p>

        <ul class="ap-hero-meta" style="opacity: 0;">
          <li><span>Base</span><strong>Alto Adige</strong></li>
          <li><span>Team</span><strong>Due fondatori</strong></li>
          <li><span>Metodo</span><strong>AI-augmented</strong></li>
        </ul>
      </div>

      <div class="hero-scroll-hint ap-hero-scroll" style="opacity: 0;" aria-hidden="true">
        <span class="hero-scroll-label">Scorri</span>
        <span class="hero-scroll-line"></span>
      </div>
    </section>

    <!-- MANIFESTO — statement gigante distribuito su griglia: kicker + segno,
         frase con accenti, nota di rinforzo offset nello spazio negativo. -->
    <section class="ap-section ap-manifesto">
      <div class="works-screen">
        <div class="ap-manifesto-grid">
          <div class="ap-manifesto-lead">
            <span class="works-kicker">Il manifesto</span>
            <span class="ap-manifesto-mark" aria-hidden="true">✦</span>
          </div>

          <BlurText
            client:visible
            text="Un piccolo team con gli strumenti giusti batte un'agenzia intera."
            animateBy="words"
            direction="top"
            delay={120}
            stepDuration={0.4}
            className="ap-statement font-display ap-statement--blur"
          />

          <div class="ap-manifesto-aside" data-ap-reveal>
            <p class="ap-manifesto-note"><strong>Meno passaggi.</strong> Una sola voce, dallo sketch al lancio.</p>
            <p class="ap-manifesto-note"><strong>Più cura.</strong> Ogni dettaglio passa due volte sotto i nostri occhi.</p>
            <p class="ap-manifesto-note"><em>Tecnologia di frontiera</em> in ogni riga, mai per moda — solo quando lavora per te.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- IL DUO — un ritratto per riga, bio estesa e aree di focus. -->
    <section class="ap-section ap-section--deeper">
      <div class="works-screen">
        <div class="works-head">
          <div class="works-head-left">
            <span class="works-kicker">Il duo</span>
            <h2 class="works-title">Julian <em>&</em> Alice.</h2>
          </div>
        </div>

        <div class="ap-duo">
          {people.map((person, i) => (
            <div class={`ap-person${i % 2 === 1 ? " ap-person--flip" : ""}`}>
              <!-- Badge appeso (2D, scroll-driven): cala dall'alto quando il
                   blocco persona entra in vista e resta fisso. Stesso
                   componente per Julian e Alice. -->
              <HangBadge
                initial={person.initial}
                name={person.name}
                role={person.role}
                grad={person.grad}
                photo={person.photo || undefined}
              />
              <div class="ap-bio">
                <span class="ap-bio-role">{person.role}</span>
                <h3 class="ap-bio-name font-display">{person.name}<em>.</em></h3>
                <p class="ap-bio-text">{person.bio}</p>
                <ul class="ap-focus">
                  {person.focus.map((f) => <li>{f}</li>)}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- IL PERCORSO — scrollytelling: timeline centrale alternata, barra di
         progressione che si riempie in scroll, badge SVG animati per step. -->
    <section class="ap-section ap-journey">
      <div class="works-screen">
        <div class="works-head">
          <div class="works-head-left">
            <span class="works-kicker">Il percorso</span>
            <h2 class="works-title">Da studenti <em>a studio.</em></h2>
          </div>
        </div>

        <ol class="ap-timeline">
          <span class="ap-line" aria-hidden="true"></span>
          {steps.map((s, i) => (
            <li class={`ap-step ap-step--${i % 2 === 0 ? "left" : "right"}`}>
              <div class="ap-step-art" set:html={journeyArt[s.art]}></div>
              <div class="ap-step-body">
                <span class="ap-step-year">{s.year}</span>
                <span class="ap-step-kicker">{s.kicker}</span>
                <h3 class="ap-step-title font-display">{s.title}</h3>
                <p class="ap-step-text" data-glow>{s.text}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- COME LAVORIAMO — niente contenitore: vive sul plain background. A
         sinistra copy + intro, a destra lo stack di card (CardSwap) che si
         avvicendano da sole e al click, con hint finché non interagisci. -->
    <section class="ap-section ap-flow ap-flow--plain">
      <div class="works-screen">
        <div class="ap-flow-inner ap-flow-inner--swap">
          <div class="ap-flow-copy">
            <span class="works-kicker ap-flow-kicker">Come lavoriamo</span>
            <h2 class="works-title ap-flow-title">
              Umani al timone, <em>AI in sala macchine.</em>
            </h2>
            <p class="ap-flow-lead">
              Dalla prima ricerca fino al lancio, ogni fase passa dalle nostre
              mani: l'AI accelera, le decisioni le prendiamo noi. Quattro passi,
              un solo standard.
            </p>
          </div>

          <div class="ap-flow-stage">
            <FlowCardSwap client:visible items={workflow} />
          </div>
        </div>
      </div>
    </section>

    <!-- SEPARATORE — hairline minimale (sostituisce il vecchio marquee). -->
    <hr class="section-rule" aria-hidden="true" />

    <!-- OUTRO — chiusura del manifesto: lo statement-firma dello studio in
         scala monumentale, spostato qui dalla homepage. Non è una CTA (quella
         vera è subito sotto): chiude la storia. -->
    <div class="about-outro about-content about-outro--standalone">
      <span class="deco deco--plus deco-accent deco-float-2" style="left: 15%; top: 16%;" aria-hidden="true"></span>
      <span class="deco deco--ring deco-peri deco-float-1" style="right: 13%; bottom: 32%;" aria-hidden="true"></span>
      <div class="about-duo" data-anim="duo">
        <span class="duo-names font-display">Persone, <em>non</em> agenzie.</span>
        <span class="duo-cta duo-cta--static">
          Le stesse mani, dallo sketch al lancio
        </span>
      </div>
    </div>

    <!-- CTA FINALE — non più una card: un invito pulito su warm white che
         rimanda al form vero, in homepage (#contatti). -->
    <section id="contatti" class="about-cta" data-anim="contact">
      <span class="about-cta-glow" aria-hidden="true"></span>
      <span class="deco deco--star deco-accent deco-float-2" style="left: 12%; top: 22%;" aria-hidden="true">✦</span>
      <span class="deco deco--ring deco-peri deco-float-1" style="right: 13%; bottom: 24%;" aria-hidden="true"></span>

      <span class="works-kicker about-cta-kicker">Iniziamo</span>

      <h2 class="about-cta-title font-display">
        Ora che ci conosci, <em>parliamo di te.</em>
      </h2>

      <p class="about-cta-sub">
        Una consulenza gratuita di 30 minuti: nessun impegno,
        solo idee chiare per far crescere la tua attività.
      </p>

      <div class="about-cta-actions">
        <a href="/#contatti" class="about-cta-btn magnetic">
          Compila il form <span aria-hidden="true">↗</span>
        </a>
        <a href="mailto:hello@auralpdigital.com" class="about-cta-mail">
          oppure scrivici a hello@auralpdigital.com
        </a>
      </div>

      <div class="about-cta-foot">
        <span>Risposta entro 24 ore</span>
        <span class="cta-foot-dot" aria-hidden="true"></span>
        <span>Nessun impegno</span>
        <span class="cta-foot-dot" aria-hidden="true"></span>
        <span>Budget chiari da subito</span>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
