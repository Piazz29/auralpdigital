---
// ContactForm — vive DENTRO la card 3D di <ContainerScroll>. Multilingua: i
// testi vengono dal dizionario; le stringhe usate da main.ts per comporre il
// mailto e il messaggio di stato sono esposte come data-* sul <form>, così la
// logica JS resta una sola e parla la lingua della pagina.
import type { Lang } from "../i18n";
import { defaultLang, getDict } from "../i18n";
import Rich from "./Rich.astro";

interface Props {
  lang?: Lang;
}
const { lang = defaultLang } = Astro.props;
const t = getDict(lang);
const cf = t.contactForm;
---

<div class="cform-layout">
  <!-- ASIDE — pannello accent: cosa succede dopo + contatti diretti. -->
  <aside class="cform-aside">
    <span class="cform-aside-star" aria-hidden="true">✦</span>
    <span class="cform-aside-label">{cf.asideLabel}</span>
    <h3 class="cform-aside-title font-display"><Rich text={cf.asideTitle} /></h3>

    <ol class="cform-steps">
      {cf.steps.map((s, i) => (
        <li class="cform-step">
          <span class="cform-step-num">{`0${i + 1}`}</span>
          <span class="cform-step-text">{s}</span>
        </li>
      ))}
    </ol>

    <div class="cform-aside-contact">
      <a href="mailto:hello@auralpdigital.com" class="cform-aside-mail">hello@auralpdigital.com</a>
      <span class="cform-aside-note">{cf.asideNote}</span>
    </div>
  </aside>

  <!-- FORM -->
  <form
    class="cform"
    data-contact-form
    novalidate
    data-status-opening={cf.statusOpening}
    data-mail-subject={cf.mail.subject}
    data-mail-name={cf.mail.name}
    data-mail-email={cf.mail.email}
    data-mail-business={cf.mail.business}
    data-mail-budget={cf.mail.budget}
    data-mail-project={cf.mail.projectHeading}
    data-mail-empty={cf.mail.empty}
  >
    <div class="cform-grid">
      <label class="cform-field">
        <span class="cform-label">{cf.fields.name}</span>
        <input
          class="cform-input"
          type="text"
          name="nome"
          required
          autocomplete="name"
          placeholder={cf.placeholders.name}
        />
      </label>

      <label class="cform-field">
        <span class="cform-label">{cf.fields.email}</span>
        <input
          class="cform-input"
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder={cf.placeholders.email}
        />
      </label>

      <label class="cform-field cform-field--full">
        <span class="cform-label">{cf.fields.business}</span>
        <input
          class="cform-input"
          type="text"
          name="attivita"
          autocomplete="organization"
          placeholder={cf.placeholders.business}
        />
      </label>

      <label class="cform-field cform-field--full">
        <span class="cform-label">{cf.fields.project}</span>
        <textarea
          class="cform-input cform-textarea"
          name="messaggio"
          rows="3"
          required
          placeholder={cf.placeholders.project}></textarea>
      </label>
    </div>

    <fieldset class="cform-budget">
      <legend class="cform-label">
        {cf.budgetLegend} <span class="cform-optional">{cf.budgetOptional}</span>
      </legend>
      <div class="cform-chips">
        {cf.budgets.map((b) => (
          <label class="cform-chip">
            <input type="radio" name="budget" value={b} />
            <span>{b}</span>
          </label>
        ))}
      </div>
    </fieldset>

    <div class="cform-actions">
      <button class="cform-submit" type="submit">
        {cf.submit} <span aria-hidden="true">↗</span>
      </button>
      <span class="cform-note">{cf.submitNote}</span>
    </div>

    <p class="cform-status" data-form-status aria-live="polite"></p>
  </form>
</div>
