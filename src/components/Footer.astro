---
// FOOTER — condiviso tra homepage e pagine interne, multilingua. `home`
// mantiene le ancore "#sezione" sulla home; `lang` localizza testi e link.
import type { Lang } from "../i18n";
import { defaultLang, getDict, localePath } from "../i18n";
import Rich from "./Rich.astro";

interface Props {
  home?: boolean;
  lang?: Lang;
}
const { home = false, lang = defaultLang } = Astro.props;
const t = getDict(lang);
const homeHref = localePath(lang, "/");
const anchor = (id: string) => (home ? `#${id}` : `${homeHref}#${id}`);
const aboutHref = localePath(lang, "/chi-siamo");
---

<footer id="info" class="site-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <img src="/logo/wordmark.svg" alt="AuralpDigital" class="footer-logo" />
        <p class="footer-tagline">
          <Rich text={t.footer.tagline} />
        </p>
      </div>

      <nav class="footer-col" aria-label="Footer">
        <span class="footer-col-label">{t.footer.menuLabel}</span>
        <a href={anchor("projects")} class="footer-link">{t.footer.links.projects}</a>
        <a href={anchor("cosa-facciamo")} class="footer-link">{t.footer.links.services}</a>
        <a href={aboutHref} class="footer-link">{t.footer.links.about}</a>
        <a href={anchor("contatti")} class="footer-link">{t.footer.links.contact}</a>
      </nav>

      <div class="footer-col">
        <span class="footer-col-label">{t.footer.contactLabel}</span>
        <a href="mailto:hello@auralpdigital.com" class="footer-link">hello@auralpdigital.com</a>
        <span class="footer-muted">{t.footer.muted}</span>
        <div class="footer-social">
          <a href="#" class="footer-social-link" aria-label="Instagram">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none" />
            </svg>
          </a>
          <a href="#" class="footer-social-link" aria-label="LinkedIn">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="4" />
              <line x1="7.2" y1="10.5" x2="7.2" y2="16.5" />
              <circle cx="7.2" cy="7.4" r="1.05" fill="currentColor" stroke="none" />
              <path d="M11 16.5v-3.4a2.1 2.1 0 0 1 4.2 0v3.4" />
              <line x1="11" y1="10.5" x2="11" y2="16.5" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="footer-rule" aria-hidden="true"></div>

    <div class="footer-bottom">
      <span>© 2026 AuralpDigital</span>
      <span>{t.footer.location}</span>
      <span>{t.footer.madeWith} <span class="footer-star" aria-hidden="true">✦</span></span>
    </div>
  </div>

  <!-- Ghost wordmark — gigante, sfuma verso il fondo pagina. -->
  <div class="footer-ghost font-display" aria-hidden="true">AuralpDigital</div>
</footer>
