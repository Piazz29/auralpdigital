---
// TypeCloudSection — statement "Il punto" reso come CILINDRO 3D orizzontale.
//
// Concetto: un cilindro invisibile con asse orizzontale; il testo è scritto
// riga per riga sulla sua superficie interna. La riga al centro del viewport è
// piatta e leggibile; salendo/scendendo le righe si inclinano (rotateX), si
// schiacciano (scaleY) e sfumano, come se curvassero dietro la superficie.
//
// Markup statico qui (convenzione del progetto: i .astro descrivono la scena,
// tutta la logica GSAP/ScrollTrigger vive in src/scripts/main.ts). Lo script
// pinna la sezione e, a ogni frame di scroll, ricalcola la trasformazione 3D di
// ogni riga in base alla sua posizione angolare sul cilindro. Senza JS / con
// prefers-reduced-motion la sezione resta un blocco statico e leggibile (la
// classe .is-cloud-pinned e lo spazio 3D vengono attivati solo da JS).
//
// I testi arrivano dal dizionario (per-lingua): ogni riga ha `text`, `tone`
// (ink scuro / accent blu+corsivo) e `size` (scala tipografica del collage).
import type { Lang } from "../i18n";
import { defaultLang, getDict } from "../i18n";

interface Props {
  lang?: Lang;
}
const { lang = defaultLang } = Astro.props;
const t = getDict(lang);
const cloud = t.home.problem.cloud;
---

<section id="problema" class="typecloud-section" data-typecloud>
  <span class="works-kicker typecloud-kicker">{t.home.problem.kicker}</span>

  <!-- Viewport = contenitore con perspective: stabilisce lo spazio 3D. Il track
       (preserve-3d) tiene le righe, ciascuna posizionata sul cilindro via JS. -->
  <div class="typecloud-viewport" data-typecloud-viewport>
    <div class="typecloud-track font-display" data-typecloud-track>
      {
        cloud.map((row) => (
          <span class={`typecloud-row typecloud-row--${row.tone} tc-${row.size}`}>
            {row.text}
          </span>
        ))
      }
    </div>
  </div>
</section>
